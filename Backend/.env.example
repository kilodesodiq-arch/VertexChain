# ============================================
# Application Configuration
# ============================================

# PORT (optional)
# The port on which the backend API server will run
# Default: 3000
PORT=3000

# NODE_ENV (optional)
# Application environment mode
# Values: development | production | test
# Default: development
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# PostgreSQL database connection settings
# All database variables are REQUIRED for the application to connect to PostgreSQL

# DATABASE_HOST (required)
# Hostname or IP address of the PostgreSQL server
# Example: localhost (for local dev) or db.example.com (for remote)
DATABASE_HOST=localhost

# DATABASE_PORT (required)
# PostgreSQL server port
# Default PostgreSQL port: 5432
DATABASE_PORT=5432

# DATABASE_USER (required)
# PostgreSQL username with access to the database
# Example: postgres (default superuser) or your custom user
DATABASE_USER=postgres

# DATABASE_PASSWORD (required)
# Password for the DATABASE_USER
# IMPORTANT: Never commit real passwords. Get from your local PostgreSQL setup
DATABASE_PASSWORD=your_secure_password_here

# DATABASE_NAME (required)
# Name of the PostgreSQL database to use
# Example: vertexchain_dev
DATABASE_NAME=vertexchain_dev

# ============================================
# Stellar/Soroban Blockchain Configuration
# ============================================
# Configuration for interacting with Stellar blockchain and Soroban smart contracts

# SOROBAN_RPC_URL (required)
# RPC endpoint for Soroban (Stellar smart contract platform)
# Testnet: https://soroban-testnet.stellar.org
# Mainnet: https://soroban-mainnet.stellar.org
# Default: https://soroban-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# STELLAR_NETWORK_PASSPHRASE (required)
# Network passphrase for Stellar transactions
# Testnet: "Test SDF Network ; September 2015"
# Mainnet: "Public Global Stellar Network ; September 2015"
# Default: Test SDF Network ; September 2015
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# CONTRACT_ID_GIST_REGISTRY (required)
# The Soroban contract ID for the Gist Registry contract
# Get this after deploying the contract to Soroban testnet/mainnet
# Leave empty if not yet deployed
CONTRACT_ID_GIST_REGISTRY=

# STELLAR_SECRET_KEY (optional)
# Stellar secret key for backend signing (S-prefixed secret key)
# Used for submitting transactions to Soroban from the backend
# IMPORTANT: Never commit real secret keys. Generate from Stellar Laboratory or CLI
# Leave empty if transactions are only signed client-side
STELLAR_SECRET_KEY=

# ============================================
# IPFS / Pinata Configuration
# ============================================
# Configuration for pinning gist content to IPFS via Pinata service

# PINATA_API_KEY (optional)
# Your Pinata API key for IPFS pinning
# Get from: https://app.pinata.cloud/keys
# Leave empty to use mock CIDs in development
PINATA_API_KEY=

# PINATA_SECRET_KEY (optional)
# Your Pinata secret key (JWT) for authenticated requests
# Get from: https://app.pinata.cloud/keys
# Leave empty to use mock CIDs in development
PINATA_SECRET_KEY=

# ============================================
# Security & CORS Configuration
# ============================================

# CORS_ORIGINS (optional)
# Comma-separated list of allowed origins for Cross-Origin Resource Sharing
# Default: http://localhost:3001,http://localhost:8081
# Production example: https://app.vertexchain.io,https://analytics.vertexchain.io
CORS_ORIGINS=http://localhost:3001,http://localhost:8081

# ============================================
# Rate Limiting / Throttling Configuration
# ============================================

# THROTTLE_TTL_MS (optional)
# Time-to-live for throttle tracking in milliseconds
# Defines the time window for rate limiting
# Default: 60000 (1 minute)
THROTTLE_TTL_MS=60000

# THROTTLE_LIMIT (optional)
# Maximum number of requests allowed per TTL window
# Default: 10 requests per minute
THROTTLE_LIMIT=10

# ============================================
# Redis Cache Configuration
# ============================================

# REDIS_URL (optional)
# Redis connection URL for caching layer
# Format: redis://[password@]host:port/db
# Example: redis://localhost:6379/0
# Example with password: redis://:password@localhost:6379/0
# Example with ElastiCache: redis://my-cluster.xxxxxx.use1.cache.amazonaws.com:6379/0
# Leave empty to disable caching (degrades gracefully)
REDIS_URL=
